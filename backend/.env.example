# Copy these values into backend/.env only if you prefer storing backend env
# separately from the root .env file. The backend loads both, and backend/.env
# overrides the root file when both are present.

AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=your-dynamodb-table
BEDROCK_MODEL_ID=your-bedrock-model-or-inference-profile-arn

AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SESSION_TOKEN=

BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=
BEDROCK_AWS_SESSION_TOKEN=

BEDROCK_CONNECT_TIMEOUT=10
BEDROCK_READ_TIMEOUT=180

EMBEDDING_MODEL=all-MiniLM-L6-v2
COMPLIANCE_INDEX_PATH=embeddings/compliance_index
AZURE_INDEX_PATH=embeddings/azure_index
GCP_INDEX_PATH=embeddings/gcp_index

COMPLIANCE_DOCS_DIR=docs/compliance
AZURE_DOCS_DIR=docs/providers/azure
GCP_DOCS_DIR=docs/providers/gcp
